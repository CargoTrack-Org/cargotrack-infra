# Terraform working directory
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform CLI configuration files
.terraformrc
terraform.rc

# Terraform plan files (both with and without extension)
*.tfplan
*.plan
tfplan
tfplan*

# Lock file (keep for reproducible builds)
# !.terraform.lock.hcl

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Terraform state snapshot exports (should NOT be committed — use remote S3 backend)
terraform-state.json
terraform-state*.json
*.tfstate.backup